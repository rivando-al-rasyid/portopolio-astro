---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BlogDetailPage } from '../../features/blog/BlogDetailPage';
import { getBlogPostBySlug } from '../../lib/contentService';
import { generateSeoDescription, generateSeoTitle } from '../../lib/utils';

const slug = Astro.params.slug ?? '';
const post = await getBlogPostBySlug(slug);

if (!post) {
  Astro.response.status = 404;
}

const title = post ? post.meta_title || generateSeoTitle(post.title) : 'Post not found';
const description = post ? post.meta_description || generateSeoDescription({ description: post.excerpt, content: post.content }) : 'The requested post could not be found.';
---

<BaseLayout title={title} description={description} image={post?.cover_image ?? null} type="article">
  {post ? <BlogDetailPage post={post} client:load /> : (
    <section class="mx-auto max-w-3xl px-4 py-16">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-primary">404</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight">Post not found</h1>
      <p class="mt-4 text-muted-foreground">The post slug does not exist or is not available.</p>
      <a class="mt-6 inline-flex text-primary hover:underline" href="/blog">Back to blog</a>
    </section>
  )}
</BaseLayout>
