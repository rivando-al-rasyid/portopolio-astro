---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ProjectDetailPage } from '../../features/projects/ProjectDetailPage';
import { getProjectBySlug } from '../../lib/contentService';
import { generateSeoDescription, generateSeoTitle } from '../../lib/utils';

const slug = Astro.params.slug ?? '';
const project = await getProjectBySlug(slug);

if (!project) {
  Astro.response.status = 404;
}

const title = project ? project.meta_title || generateSeoTitle(project.title) : 'Project not found';
const description = project ? project.meta_description || generateSeoDescription({ description: project.summary, content: project.content }) : 'The requested project could not be found.';
---

<BaseLayout title={title} description={description} image={project?.image_url ?? null} type="article">
  {project ? <ProjectDetailPage project={project} client:load /> : (
    <section class="mx-auto max-w-3xl px-4 py-16">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-primary">404</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight">Project not found</h1>
      <p class="mt-4 text-muted-foreground">The project slug does not exist or is not available.</p>
      <a class="mt-6 inline-flex text-primary hover:underline" href="/projects">Back to projects</a>
    </section>
  )}
</BaseLayout>
