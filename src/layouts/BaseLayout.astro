---
import Navbar from '../components/Navbar';
import '../styles/index.css';

interface Props {
  title?: string;
  description?: string;
  image?: string | null;
  type?: 'website' | 'article';
}

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321').replace(/\/$/, '');
const {
  title = 'Portfolio Knowledge Graph',
  description = 'A modern portfolio CMS with blog, projects, graph relations, social sharing.',
  image = null,
  type = 'website'
} = Astro.props;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const pageTitle = title === 'Portfolio Knowledge Graph' ? title : `${title} | Portfolio Knowledge Graph`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    {image ? <meta property="og:image" content={image} /> : null}
    <script is:inline>
      try {
        if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
      } catch {}
    </script>
  </head>
  <body>
    <div class="min-h-screen bg-background text-foreground">
      <Navbar client:load />
      <main>
        <slot />
      </main>
      <footer class="border-t py-10">
        <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 text-sm text-muted-foreground md:flex-row md:items-center md:justify-between">
          <p>© {new Date().getFullYear()} Knowledge Portfolio. Built with Astro SSR, React islands, Tailwind 4, and Payload CMS.</p>
          <div class="flex gap-3">
            <a class="hover:text-foreground" href="mailto:hello@example.com" aria-label="Email">Email</a>
            <a class="hover:text-foreground" href="https://github.com" target="_blank" rel="noreferrer" aria-label="GitHub">GitHub</a>
            <a class="hover:text-foreground" href="https://linkedin.com" target="_blank" rel="noreferrer" aria-label="LinkedIn">LinkedIn</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
